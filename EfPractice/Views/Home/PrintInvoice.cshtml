@model EfPractice.Models.InvoiceModel
@{
    Layout = null;
    var dt = Model.InvoiceDate.ToString("MMM dd, yyyy");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.InvoiceRefNo</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            font-size: 12px;
            color: #222;
            margin: 16px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .logo {
            max-width: 150px;
        }

        .company-info {
            text-align: right;
            font-size: 11px;
        }

        .invoice-title {
            font-size: 18px;
            font-weight: 600;
            margin-top: 8px;
            text-align: right;
        }

        .panel {
            border: 1px solid #999;
            margin-top: 10px;
            padding: 6px;
            font-size: 11px;
        }

            .panel table {
                width: 100%;
                border-collapse: collapse;
            }

            .panel th, .panel td {
                padding: 4px;
                border: 1px solid #ccc;
                text-align: left;
                font-size: 11px;
            }

            .panel th {
                background: #f0f0f0;
            }

        .totals {
            margin-top: 6px;
            width: 300px;
            float: right;
            font-size: 11px;
        }

            .totals table {
                width: 100%;
                border-collapse: collapse;
            }

            .totals td {
                padding: 4px;
            }

        .qr-fbr {
            margin-top: 16px;
            text-align: center;
        }

        .signatures {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
            font-size: 11px;
        }

            .signatures div {
                text-align: center;
            }

        @@media print {
            .print-actions {
                display: none;
            }

            body {
                margin: 6mm;
            }
        }

        .print-actions {
            position: fixed;
            top: 8px;
            right: 12px;
        }

        .btn {
            background: #0d6efd;
            color: #fff;
            border: none;
            padding: 6px 12px;
            font-size: 12px;
            cursor: pointer;
            border-radius: 3px;
        }

            .btn.secondary {
                background: #6c757d;
            }
    </style>
</head>
<body>

    <div class="print-actions">
        <button class="btn" onclick="window.print()">Print</button>
        <button class="btn secondary" onclick="window.close()">Close</button>
    </div>
    <br />
    <br />
    <br />
    <div class="header">
        <div class="logo">
            <img src="@Url.Content(string.IsNullOrWhiteSpace(Model.SellerLogoPath) ? "~/images/company-logo.png" : Model.SellerLogoPath)" alt="Logo" style="max-width:100%;" />
        </div>
        <div class="company-info">
            <strong style="font-weight: 700;font-size: 25px;">@Model.SellerBusinessName</strong><br />
            @Model.SellerAddress<br />
            Phone: @Model.SellerPhone <br />
            Email: @Model.SellerEmail<br />
            NTN: @Model.SellerNTNCNIC
        </div>
    </div>

    <div class="invoice-title">SALES RETAIL TAX INVOICE</div>

    <div>
        <div><span>Invoice No :</span><span>@Model.invoiceNumber</span></div>
        <div><span>FBR Invoice No :</span><span>@Model.fbrinvoiceNumber</span></div>
        <div><span>Invoice Date :</span><span>@Model.InvoiceDate</span></div>
    </div>
    <div class="panel">
        <table>
            <tr>
                <th><div><strong>Bill To</strong><br /></div></th>
                <th><strong>Other Info</strong><br /></th>
            </tr>
            <tr>
                <td>
                    To: @(Model.BuyerBusinessName ?? "Walk-in (Cash) Customer")<br />
                    Address: @(Model.BuyerAddress ?? "N/A")<br />
                    Telephone: @(Model.BuyerPhone ?? "-")<br /> *
                    NTN/CNIC: @(Model.BuyerNTNCNIC ?? "-")
                </td>
                <td>
                    Ship to Address: @(Model.BuyerAddress ?? "-")
                </td>
            </tr>
        </table>
    </div>

    <div class="panel">
        <table>
            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Particular</th>
                    <th>QTY</th>
                    <th>List Price</th>
                    <th>Rate</th>
                    <th>Value Excl. Tax</th>
                    <th>Sales Tax</th>
                    <th>Discount</th>
                    <th>Value Incl. Tax</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items != null && Model.Items.Any())
                {
                    int idx = 1;
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@idx</td>
                            <td>@item.ProductDescription</td>
                            <td>@item.Quantity</td>
                            <td>@item.ListPrice</td>
                            <td>@item.Rate</td>
                            <td>@item.ValueSalesExcludingST.ToString("0,0")</td>
                            <td>@item.SalesTaxApplicable.ToString("0,0")</td>
                            <td>@item.ValueSalesExcludingST.ToString("0,0")</td>
                            <td>@item.TotalValues.ToString("0,0")</td>
                        </tr>
                        idx++;
                    }
                }
                else
                {
                    <tr><td colspan="9" style="text-align:center;">No items</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="totals">
        @*       <table>
            <tr><td>Total</td><td style="text-align:right;">@Model.TotalExclTax.ToString("0,0")</td></tr>
            <tr><td>Total Sales Tax</td><td style="text-align:right;">@Model.TotalTax.ToString("0,0")</td></tr>
            <tr><td><strong>Net Total</strong></td><td style="text-align:right;"><strong>@Model.NetTotal.ToString("0,0")</strong></td></tr>
        </table>
        <div>Amount In Words: @Model.AmountInWords</div> *@
    </div>

    <div class="qr-fbr">
        <img src="@Url.Content("~/images/fbr-qr.png")" alt="FBR QR" style="max-width:120px; display:block; margin:0 auto;" />
    </div>

    <div class="signatures">
        <div>Super Admin<br />Prepared By</div>
        <div>Received By</div>
        <div>Approved By</div>
    </div>

    <div style="margin-top:20px; font-size:10px; text-align:center;">Generated on @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>

</body>
</html>
