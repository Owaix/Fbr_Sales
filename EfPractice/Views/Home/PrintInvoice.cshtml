@model EfPractice.Models.InvoiceModel
@{
    Layout = null;
    var dt = Model.InvoiceDate.ToString("MMM dd, yyyy");
}

@functions {
    private static string AmountToWords(decimal amount)
    {
        long whole = (long)Math.Floor(amount);
        int cents = (int)Math.Round((amount - whole) * 100M);
        var words = NumberToWords(whole);
        if (cents > 0)
        {
            words += $" and {cents:D2}/100";
        }
        return words + " only";
    }

    private static string NumberToWords(long number)
    {
        if (number == 0) return "zero";
        if (number < 0) return "minus " + NumberToWords(Math.Abs(number));

        var unitsMap = new[] { "zero", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine", "ten", "eleven", "twelve", "thirteen", "fourteen", "fifteen", "sixteen", "seventeen", "eighteen", "nineteen" };
        var tensMap = new[] { "zero", "ten", "twenty", "thirty", "forty", "fifty", "sixty", "seventy", "eighty", "ninety" };

        string words = string.Empty;

        if ((number / 1000000000000) > 0)
        {
            words += NumberToWords(number / 1000000000000) + " trillion ";
            number %= 1000000000000;
        }
        if ((number / 1000000000) > 0)
        {
            words += NumberToWords(number / 1000000000) + " billion ";
            number %= 1000000000;
        }
        if ((number / 1000000) > 0)
        {
            words += NumberToWords(number / 1000000) + " million ";
            number %= 1000000;
        }
        if ((number / 1000) > 0)
        {
            words += NumberToWords(number / 1000) + " thousand ";
            number %= 1000;
        }
        if ((number / 100) > 0)
        {
            words += NumberToWords(number / 100) + " hundred ";
            number %= 100;
        }
        if (number > 0)
        {
            if (!string.IsNullOrEmpty(words)) words += "and ";

            if (number < 20) words += unitsMap[number];
            else
            {
                words += tensMap[number / 10];
                if ((number % 10) > 0) words += "-" + unitsMap[number % 10];
            }
        }
        return words.Trim();
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.InvoiceRefNo</title>
    <link rel="icon" href="@Model.SellerLogoPath" type="image/png">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            font-size: 12px;
            color: #222;
            margin: 16px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .logo {
            max-width: 150px;
        }

        .company-info {
            text-align: right;
            font-size: 11px;
        }

        .invoice-title {
            font-size: 18px;
            font-weight: 600;
            margin-top: 8px;
            text-align: right;
        }

        .panel {
            margin-top: 10px;
            padding: 6px;
            font-size: 11px;
        }

            .panel table {
                width: 100%;
                border-collapse: collapse;
            }

            .panel th, .panel td {
                padding: 4px;
                border: 1px solid #ccc;
                text-align: left;
                font-size: 11px;
            }

            .panel th {
            }

        .totals {
            margin-top: 6px;
            width: 300px;
            float: right;
            font-size: 11px;
        }

            .totals table {
                width: 100%;
                border-collapse: collapse;
            }

            .totals td {
                padding: 4px;
            }

        .qr-fbr {
            margin-top: 16px;
            text-align: center;
        }

        .signatures {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            padding-left: 10%;
            padding-right: 10%;
        }

            .signatures div {
                text-align: center;
            }

        @@media print {
            .print-actions {
                display: none;
            }

            body {
                margin: 6mm;
            }
        }

        .print-actions {
            position: fixed;
            top: 8px;
            right: 12px;
        }

        .btn {
            background: #0d6efd;
            color: #fff;
            border: none;
            padding: 6px 12px;
            font-size: 12px;
            cursor: pointer;
            border-radius: 3px;
        }

            .btn.secondary {
                background: #6c757d;
            }

        .bold {
            font-weight: bold;
        }

        .rmlr {
            border-left-style: hidden !important;
            border-right-style: hidden !important;
        }
    </style>
</head>
<body>

    <div class="print-actions">
        <button class="btn" onclick="window.print()">Print</button>
        <button class="btn secondary" onclick="window.close()">Close</button>
    </div>
    <br />
    <br />
    <div class="header">
        <div class="logo">
            <img src="@Url.Content(string.IsNullOrWhiteSpace(Model.SellerLogoPath) ? "~/images/company-logo.png" : Model.SellerLogoPath)" alt="Logo" style="max-width:100%;" />
        </div>
        <div class="company-info">
            <strong style="font-weight: 700;font-size: 25px;">@Model.SellerBusinessName</strong><br />
            @Model.SellerAddress<br />
            Phone: @Model.SellerPhone <br />
            Email: @Model.SellerEmail<br />
            NTN: @Model.SellerNTNCNIC
        </div>
    </div>

    <div class="invoice-title">SALES RETAIL TAX INVOICE</div>

    <div>
        <div><span class="bold">Invoice No :</span><span>@Model.invoiceNumber</span></div>
        <div><span class="bold">FBR Invoice No :</span><span>@Model.fbrinvoiceNumber</span></div>
        <div><span class="bold">Invoice Date :</span><span>@Model.InvoiceDate</span></div>
    </div>
    <div class="panel">
        <table>
            <tr>
                <th><div><br /><strong>Bill To</strong><br /></div><br /></th>
                <th><strong>Other Info</strong><br /></th>
            </tr>
            <tr>
                <td>
                    To: <span class="bold">@(Model.BuyerBusinessName ?? "Walk-in (Cash) Customer")</span> <br />
                    Address: <span class="bold">@(Model.BuyerAddress ?? "N/A")</span> <br />
                    Telephone:<span class="bold"> @(Model.BuyerPhone ?? "-")</span> <br /> *
                    NTN/CNIC:<span class="bold"> @(Model.BuyerNTNCNIC ?? "-")</span>
                </td>
                <td>
                    Ship to Address: <span class="bold">@(Model.BuyerAddress ?? "-")</span>
                </td>
            </tr>
        </table>
    </div>

    <div class="panel">
        <table>
            <thead>
                <tr>
                    <th><div><br /><strong>S.No</strong></div><br /></th>
                    <th>Particular</th>
                    <th>QTY</th>
                    <th>List Price</th>
                    <th>Rate</th>
                    <th>Value Excl. Tax</th>
                    <th>Sales Tax</th>
                    <th>Discount</th>
                    <th>Value Incl. Tax</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items != null && Model.Items.Any())
                {
                    int idx = 1;
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@idx</td>
                            <td class="rmlr">@item.ProductDescription</td>
                            <td class="rmlr">@item.Quantity</td>
                            <td class="rmlr">@item.ListPrice</td>
                            <td class="rmlr">@item.Rate</td>
                            <td class="rmlr">@item.ValueSalesExcludingST.ToString("0,0")</td>
                            <td class="rmlr">@item.SalesTaxApplicable.ToString("0,0")</td>
                            <td class="rmlr">@item.ValueSalesExcludingST.ToString("0,0")</td>
                            <td>@item.TotalValues.ToString("0,0")</td>
                        </tr>
                        idx++;
                    }
                }
                else
                {
                    <tr><td colspan="9" style="text-align:center;">No items</td></tr>
                }
            </tbody>
            @{
                var itemCount = Model.Items?.Count ?? 0;
                decimal totalRetail = Model.Items?.Sum(i => i.ValueSalesExcludingST) ?? 0M;
                decimal totalST = Model.Items?.Sum(i => i.SalesTaxApplicable) ?? 0M;
                decimal totalIncl = Model.Items?.Sum(i => i.TotalValues) ?? 0M;
                decimal navyLevy = Model.Items?.Sum(i => i.SalesTaxWithheldAtSource ?? 0M) ?? 0M;
                decimal totalAddTax = Model.Items?.Sum(i => i.ExtraTax ?? 0M) ?? 0M;
                decimal netTotal = totalIncl + totalAddTax;
                string fmt(decimal d) => d.ToString("N2");
            }
            <tfoot>
                <tr>
                    <td colspan="6"><strong>Total Items:</strong> @itemCount</td>
                    <td class="text-end rmlr"><br /><strong>@fmt(totalRetail)</strong></td>
                    <td class="text-end rmlr">@fmt(totalST)</></td>
                    <td class="text-end"><br /><strong>@fmt(totalIncl)</strong></td>
                </tr>
                <tr>
                    <td colspan="7"></td>
                    <td class="text-end rmlr bold">Navy Levy</td>
                    <td class="text-end">@fmt(navyLevy)</td>
                </tr>
                <tr>
                    <td colspan="7"></td>
                    <td class="text-end rmlr bold">Total Additional Tax</td>
                    <td class="text-end">@fmt(totalAddTax)</td>
                </tr>
                <tr>
                    <td colspan="7"></td>
                    <td class="text-end rmlr"><strong>Net Total</strong></td>
                    <td class="text-end"><strong>@fmt(netTotal)</strong></td>
                </tr>
                <tr>
                    <td colspan="9" style="text-align: right;"><strong>Amount in Words:</strong> @AmountToWords(netTotal)</td>
                </tr>
                <tr>
                    <td colspan="9">
                        <div class="qr-fbr">
                            <img src="@Url.Content("~/images/download.png")" alt="FBR QR" style="max-width:120px; display:block; margin:0 auto;" />
                            <img src="@Url.Content("~/images/fbr.png")" style="max-width:120px; display:block; margin:0 auto;" />
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="signatures">
        <div>Super Admin<br /><span>Prepared By</span></div>
        <div><span>Received By</span></div>
        <div><span>Approved By</span></div>
    </div>

    <div style="margin-top:20px; font-size:10px; text-align:center;">Generated on @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>

</body>
</html>
